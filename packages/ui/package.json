{
  "name": "@carbonforge/ui",
  "version": "0.1.0",
  "description": "Enterprise React patterns built on IBM Carbon Design System.",
  "type": "module",
  "sideEffects": [
    "*.scss",
    "**/*.scss"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --sourcemap --clean && npm run build:styles",
    "build:styles": "sass src/styles/index.scss dist/styles.css --style=compressed",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "eslint src",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@carbon/react": "^1.110.0",
    "@carbon/icons-react": "^11.60.0",
    "react": "^18.3.1 || ^19.0.0",
    "react-dom": "^18.3.1 || ^19.0.0"
  },
  "devDependencies": {
    "@carbon/icons-react": "^11.60.0",
    "@carbon/react": "^1.110.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sass": "1.69.7",
    "tsup": "^8.3.5",
    "vitest": "^2.1.8"
  }
}
